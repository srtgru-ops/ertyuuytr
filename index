<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>لوحة تصريف أكواد الفاونديشن</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  :root{--bg:#0b1220;--card:#111b2e;--card2:#16233a;--text:#eef4ff;--muted:#9fb1cc;--line:#263954;--blue:#2f80ed;--cyan:#00b4c6;--green:#27ae60;--red:#e74c3c;--orange:#f2994a;--purple:#9b51e0;--shadow:0 18px 40px rgba(0,0,0,.28);--radius:20px}
  [data-theme="light"]{--bg:#f4f7fb;--card:#fff;--card2:#f8fbff;--text:#142033;--muted:#65758b;--line:#dfe8f3;--shadow:0 14px 35px rgba(28,45,70,.10)}
  *{box-sizing:border-box} body{margin:0;background:radial-gradient(circle at top left,rgba(47,128,237,.18),transparent 35%),var(--bg);color:var(--text);font-family:Tahoma,Arial,sans-serif}.wrap{max-width:1480px;margin:auto;padding:24px}.top{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;margin-bottom:20px}.title h1{margin:0;font-size:30px}.title p{margin:8px 0 0;color:var(--muted);line-height:1.8}.actions{display:flex;gap:10px;flex-wrap:wrap}.btn{border:1px solid var(--line);background:var(--card);color:var(--text);padding:11px 14px;border-radius:14px;cursor:pointer;box-shadow:var(--shadow);transition:.25s}.btn:hover{transform:translateY(-2px)}
  .grid{display:grid;gap:16px}.kpis{grid-template-columns:repeat(4,1fr)}.card{background:linear-gradient(180deg,var(--card),var(--card2));border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:18px;overflow:hidden}.kpi .label{color:var(--muted);font-size:13px}.kpi .value{font-size:28px;font-weight:900;margin:8px 0}.kpi .sub{font-size:12px;color:var(--muted);line-height:1.7}.badge{display:inline-flex;gap:6px;align-items:center;border-radius:999px;padding:6px 10px;font-size:12px;margin-top:10px}.good{background:rgba(39,174,96,.14);color:#49d17c}.warn{background:rgba(242,153,74,.15);color:#ffb166}.bad{background:rgba(231,76,60,.14);color:#ff7770}.info{background:rgba(47,128,237,.15);color:#7db3ff}
  .filters{grid-template-columns:1.15fr 1.15fr 1fr 1fr 1fr 1fr;margin:16px 0}.field label{display:block;color:var(--muted);font-size:13px;margin-bottom:8px}select,input{width:100%;background:var(--bg);color:var(--text);border:1px solid var(--line);border-radius:12px;padding:11px;font-family:inherit}.rangeLine input{accent-color:var(--cyan)}
  .charts{grid-template-columns:repeat(2,1fr)}.wide{grid-column:1/-1}.card h3{margin:0 0 14px;font-size:18px}.chartBox{height:330px}.tableWrap{overflow:auto;max-height:460px;border:1px solid var(--line);border-radius:16px}table{width:100%;border-collapse:collapse;min-width:1300px}th,td{padding:12px;border-bottom:1px solid var(--line);text-align:right;font-size:13px}th{position:sticky;top:0;background:var(--card2);z-index:1;color:var(--muted)}tr:hover{background:rgba(47,128,237,.08)}.risk{font-weight:bold}.risk.high{color:#ff7770}.risk.med{color:#ffb166}.risk.low{color:#49d17c}.insights{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.insight{border:1px solid var(--line);border-radius:16px;padding:14px;background:rgba(47,128,237,.08);line-height:1.8}.pill{display:inline-block;border:1px solid var(--line);padding:5px 9px;border-radius:999px;color:var(--muted);font-size:12px}
  @media(max-width:1150px){.kpis{grid-template-columns:repeat(2,1fr)}.filters,.charts{grid-template-columns:1fr}.insights{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:720px){.wrap{padding:14px}.top{display:block}.kpis{grid-template-columns:1fr}.insights{grid-template-columns:1fr}.title h1{font-size:24px}.chartBox{height:290px}}
  @media print{.actions,.filters{display:none}.wrap{max-width:none}.card{box-shadow:none}.charts{grid-template-columns:1fr}}
</style>
</head>
<body data-theme="dark">
<div class="wrap">
  <div class="top">
    <div class="title">
      <h1>لوحة تصريف أكواد الفاونديشن — خلال شهرين</h1>
      <p>خطة تنفيذية لبيع <b>112 كود Foundation</b> قبل انتهاء الصلاحية، مع حساب الإيراد بعد خصم <b>ضريبة القيمة المضافة 15%</b> ثم خصم <b>عمولة تمارا 6%</b>، وحساب الربح الحقيقي بعد تكلفة الكود وتكلفة تقديم المدرب.</p>
      <span class="pill">SA • CS • LS • BC • BE</span>
    </div>
    <div class="actions">
      <button class="btn" onclick="toggleTheme()">تبديل الوضع</button>
      <button class="btn" onclick="resetFilters()">إعادة الفلاتر</button>
      <button class="btn" onclick="window.print()">طباعة / PDF</button>
    </div>
  </div>

  <div class="grid kpis" id="kpis"></div>

  <div class="grid filters card">
    <div class="field"><label>فلتر الكود</label><select id="codeFilter"><option value="all">الكل</option></select></div>
    <div class="field"><label>الشريحة المستهدفة</label><select id="segmentFilter"><option value="all">كل الشرائح</option></select></div>
    <div class="field"><label>مستوى الأولوية</label><select id="priorityFilter"><option value="all">كل الأولويات</option><option value="عالية">عالية</option><option value="متوسطة">متوسطة</option><option value="منخفضة">منخفضة</option></select></div>
    <div class="field"><label>الأيام المتبقية: <span id="daysLabel">60</span> يوم</label><div class="rangeLine"><input id="daysRange" type="range" min="15" max="60" value="60" /></div></div>
    <div class="field"><label>سعر البيع للكود: <span id="sellPriceLabel">900</span> ريال</label><div class="rangeLine"><input id="sellPriceRange" type="range" min="650" max="1500" value="900" step="1" /></div></div>
    <div class="field"><label>قيمة تقديم المدرب بالريال</label><input id="trainerFee" type="number" min="0" step="50" value="0" placeholder="مثال: 3000" /></div>
  </div>

  <div class="grid charts">
    <div class="card"><h3>1) توزيع الأكواد المقترح حسب الطلب</h3><div class="chartBox"><canvas id="allocationChart"></canvas></div></div>
    <div class="card"><h3>2) درجة الطلب وسهولة البيع</h3><div class="chartBox"><canvas id="demandChart"></canvas></div></div>
    <div class="card"><h3>3) خطة البيع الأسبوعية المطلوبة</h3><div class="chartBox"><canvas id="weeklyChart"></canvas></div></div>
    <div class="card"><h3>4) أفضل الباقات للتصريف السريع</h3><div class="chartBox"><canvas id="bundleChart"></canvas></div></div>
    <div class="card"><h3>5) الإيراد بعد الضريبة وعمولة تمارا حسب السعر</h3><div class="chartBox"><canvas id="revenueChart"></canvas></div></div>
    <div class="card"><h3>6) الأكواد حسب الشريحة المستهدفة</h3><div class="chartBox"><canvas id="segmentChart"></canvas></div></div>
    <div class="card"><h3>7) مخاطر عدم البيع قبل الانتهاء</h3><div class="chartBox"><canvas id="riskChart"></canvas></div></div>
    <div class="card"><h3>8) ترتيب الأولوية التنفيذي</h3><div class="chartBox"><canvas id="priorityChart"></canvas></div></div>
    <div class="card wide"><h3>9) لوحة القرار السريع</h3><div class="insights" id="insights"></div></div>
    <div class="card wide"><h3>10) جدول الأكواد والربحية بعد الضريبة وتمارا</h3><div class="tableWrap"><table id="dataTable"></table></div></div>
  </div>
</div>
<script>
const COST_USD = 190;
const USD_TO_SAR = 3.75;
const COST_SAR = COST_USD * USD_TO_SAR;
const VAT_RATE = 0.15;
const TAMARA_RATE = 0.06;
const VAT_NET_FACTOR = 1 / (1 + VAT_RATE);
const TAMARA_FACTOR = 1 - TAMARA_RATE;
const codes = [
 {code:'CS', name:'خدمة العملاء', en:'Customer Service', qty:30, demand:95, ease:92, priority:'عالية', segment:'طلاب وخريجون + موظفو استقبال', riskBase:22, strategy:'بيع كدورة مستقلة وباقة جاهزية سوق العمل'},
 {code:'LS', name:'القيادة', en:'Leadership', qty:25, demand:86, ease:82, priority:'عالية', segment:'قادة الأندية + موظفون + مشرفون', riskBase:28, strategy:'استهداف قادة الأندية والمجالس والفرق التطوعية'},
 {code:'BC', name:'التواصل الإداري', en:'Business Communication', qty:25, demand:90, ease:88, priority:'عالية', segment:'كل التخصصات + الخريجون', riskBase:24, strategy:'ضعه مع خدمة العملاء أو القيادة كباقة قوية'},
 {code:'SA', name:'المبيعات', en:'Sales', qty:20, demand:76, ease:72, priority:'متوسطة', segment:'إدارة الأعمال + التسويق', riskBase:38, strategy:'استهداف طلاب التسويق والمهتمين بالقطاع الخاص'},
 {code:'BE', name:'آداب وسلوكيات العمل', en:'Business Etiquette', qty:12, demand:62, ease:70, priority:'منخفضة', segment:'خريجون + موظفون جدد', riskBase:48, strategy:'لا يباع وحده غالبًا؛ استخدمه كبونص داخل الباقات'}
];
const bundles = [
 {name:'جاهزية سوق العمل', qty:35, demand:96},
 {name:'القيادة والمهارات الإدارية', qty:30, demand:88},
 {name:'المبيعات وخدمة العملاء', qty:25, demand:80},
 {name:'كود فردي سريع', qty:22, demand:70}
];
let charts=[];
function fmt(n){return new Intl.NumberFormat('ar-SA').format(Math.round(n));}
function sar(n){return fmt(n)+' ريال';}
function pct(n){return (Math.round(n*10)/10).toLocaleString('ar-SA')+'%';}
function moneyClass(n){return n>=0?'low':'high';}
function filtered(){const c=document.getElementById('codeFilter').value,s=document.getElementById('segmentFilter').value,p=document.getElementById('priorityFilter').value;return codes.filter(x=>(c==='all'||x.code===c)&&(s==='all'||x.segment===s)&&(p==='all'||x.priority===p));}
function currentInputs(){return {days:+document.getElementById('daysRange').value||60,sellPrice:+document.getElementById('sellPriceRange').value||0,trainerFee:+document.getElementById('trainerFee').value||0};}
function initFilters(){const cf=document.getElementById('codeFilter');codes.forEach(x=>cf.innerHTML+=`<option value="${x.code}">${x.code} — ${x.name}</option>`);const sf=document.getElementById('segmentFilter');[...new Set(codes.map(x=>x.segment))].forEach(x=>sf.innerHTML+=`<option value="${x}">${x}</option>`);['codeFilter','segmentFilter','priorityFilter','daysRange','sellPriceRange','trainerFee'].forEach(id=>document.getElementById(id).addEventListener('input',render));}
function destroy(){charts.forEach(c=>c.destroy());charts=[];}
function chart(id,type,data,options={}){const ctx=document.getElementById(id);const ch=new Chart(ctx,{type,data,options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:getComputedStyle(document.body).getPropertyValue('--text')}},tooltip:{rtl:true,bodyFont:{family:'Tahoma'},titleFont:{family:'Tahoma'}}},scales:options.noScales?{}:{x:{ticks:{color:getComputedStyle(document.body).getPropertyValue('--muted')},grid:{color:'rgba(159,177,204,.12)'}},y:{ticks:{color:getComputedStyle(document.body).getPropertyValue('--muted')},grid:{color:'rgba(159,177,204,.12)'}}},...options}});charts.push(ch);}
function finance(data){const {sellPrice,trainerFee}=currentInputs();const totalQty=data.reduce((a,b)=>a+b.qty,0);const grossRevenue=totalQty*sellPrice;const revenueAfterVat=grossRevenue*VAT_NET_FACTOR;const vatAmount=grossRevenue-revenueAfterVat;const tamaraFee=revenueAfterVat*TAMARA_RATE;const netRevenueAfterFees=revenueAfterVat-tamaraFee;const totalCodeCost=totalQty*COST_SAR;const totalCost=totalCodeCost+trainerFee;const netProfit=netRevenueAfterFees-totalCost;const margin=netRevenueAfterFees?netProfit/netRevenueAfterFees*100:0;const trainerPerCode=totalQty?trainerFee/totalQty:0;const breakEven=(COST_SAR+trainerPerCode)/(VAT_NET_FACTOR*TAMARA_FACTOR);return {sellPrice,trainerFee,totalQty,grossRevenue,revenueAfterVat,vatAmount,tamaraFee,netRevenueAfterFees,totalCodeCost,totalCost,netProfit,margin,trainerPerCode,breakEven};}
function renderKpis(data,days){const f=finance(data);const avgRisk=data.length?data.reduce((a,b)=>a+(b.riskBase+(60-days)*0.9),0)/data.length:0;const arr=[['الإيراد قبل الخصم',sar(f.grossRevenue),'قبل الضريبة وعمولة تمارا','info'],['بعد خصم الضريبة وتمارا',sar(f.netRevenueAfterFees),'الإيراد الصافي للتحصيل','good'],['الضريبة المخصومة',sar(f.vatAmount),'15% باعتبار السعر شامل الضريبة','warn'],['عمولة تمارا 6%',sar(f.tamaraFee),'محسوبة بعد خصم الضريبة','warn'],['صافي الربح/الخسارة',sar(f.netProfit),'بعد تكلفة الأكواد والمدرب',f.netProfit>=0?'good':'bad'],['نسبة الربح',pct(f.margin),'صافي الربح ÷ الإيراد الصافي',f.margin>=0?'good':'bad'],['سعر التعادل الجديد',sar(f.breakEven),'يشمل الضريبة وتمارا والمدرب','info'],['مؤشر المخاطر',Math.min(100,Math.round(avgRisk))+'%','يزيد كلما اقترب الانتهاء',avgRisk>55?'bad':'warn']];document.getElementById('kpis').innerHTML=arr.map(x=>`<div class="card kpi"><div class="label">${x[0]}</div><div class="value">${x[1]}</div><div class="sub">${x[2]}</div><span class="badge ${x[3]}">● مباشر</span></div>`).join('');}
function renderInsights(data,days){const f=finance(data);const weekly=Math.ceil(f.totalQty/(days/7));const top=[...data].sort((a,b)=>b.demand-a.demand)[0];const gap=f.breakEven-f.sellPrice;document.getElementById('insights').innerHTML=`<div class="insight"><b>الخصومات مفعّلة</b><br>تم خصم الضريبة أولًا، ثم خصم عمولة تمارا 6% من الإيراد بعد الضريبة.</div><div class="insight"><b>سعر التعادل الجديد</b><br>لا تنزل عن <b>${sar(f.breakEven)}</b> للكود حتى لا تدخل في خسارة.</div><div class="insight"><b>حالة السعر الحالي</b><br>${f.sellPrice>=f.breakEven?'السعر الحالي آمن ويحقق ربحًا.':'السعر الحالي يسبب خسارة. ارفع السعر بمقدار '+sar(gap)+' على الأقل.'}</div><div class="insight"><b>الهدف الأسبوعي</b><br>تحتاج بيع ${fmt(weekly)} كود أسبوعيًا تقريبًا لتصريف ${fmt(f.totalQty)} كود.</div><div class="insight"><b>ابدأ بـ ${top?top.code:'-'}</b><br>لأنه الأعلى في الطلب وسهل تسويقه بسرعة.</div><div class="insight"><b>تكلفة المدرب</b><br>تم توزيع ${sar(f.trainerFee)} على ${fmt(f.totalQty)} كود، أي ${sar(f.trainerPerCode)} لكل كود.</div>`;}
function renderTable(data,days){const f=finance(data);const risk=x=>Math.min(100,Math.round(x.riskBase+(60-days)*0.9));document.getElementById('dataTable').innerHTML=`<thead><tr><th>الكود</th><th>البرنامج</th><th>الكمية</th><th>إيراد قبل الخصم</th><th>الضريبة</th><th>تمارا 6%</th><th>إيراد صافي</th><th>تكلفة الأكواد</th><th>نصيب المدرب</th><th>صافي الربح</th><th>نسبة الربح</th><th>المخاطر</th><th>طريقة التسويق</th></tr></thead><tbody>`+data.map(x=>{let r=risk(x),cls=r>60?'high':r>35?'med':'low';let gross=x.qty*f.sellPrice;let revAfterVat=gross*VAT_NET_FACTOR;let vat=gross-revAfterVat;let tamara=revAfterVat*TAMARA_RATE;let netRev=revAfterVat-tamara;let cost=x.qty*COST_SAR;let trainerShare=x.qty*f.trainerPerCode;let profit=netRev-cost-trainerShare;let margin=netRev?profit/netRev*100:0;return `<tr><td><b>${x.code}</b></td><td>${x.name}<br><span class="pill">${x.en}</span></td><td>${x.qty}</td><td>${sar(gross)}</td><td>${sar(vat)}</td><td>${sar(tamara)}</td><td>${sar(netRev)}</td><td>${sar(cost)}</td><td>${sar(trainerShare)}</td><td class="risk ${moneyClass(profit)}">${sar(profit)}</td><td class="risk ${moneyClass(margin)}">${pct(margin)}</td><td class="risk ${cls}">${r}%</td><td>${x.strategy}</td></tr>`}).join('')+`</tbody>`;}
function render(){destroy();const data=filtered();const {days,sellPrice}=currentInputs();document.getElementById('daysLabel').textContent=days;document.getElementById('sellPriceLabel').textContent=fmt(sellPrice);renderKpis(data,days);renderInsights(data,days);renderTable(data,days);const labels=data.map(x=>x.code+' - '+x.name);chart('allocationChart','bar',{labels,datasets:[{label:'عدد الأكواد',data:data.map(x=>x.qty),borderWidth:1}]},{indexAxis:'y'});chart('demandChart','bar',{labels,datasets:[{label:'درجة الطلب %',data:data.map(x=>x.demand)},{label:'سهولة البيع %',data:data.map(x=>x.ease)}]});const weeks=Math.ceil(days/7),total=data.reduce((a,b)=>a+b.qty,0),per=Math.ceil(total/weeks);chart('weeklyChart','line',{labels:Array.from({length:weeks},(_,i)=>'الأسبوع '+(i+1)),datasets:[{label:'مبيعات مستهدفة تراكمية',data:Array.from({length:weeks},(_,i)=>Math.min(total,per*(i+1))),tension:.35,fill:true},{label:'الحد الأدنى الأسبوعي',data:Array.from({length:weeks},(_,i)=>per*(i+1)),tension:.35}]});chart('bundleChart','bar',{labels:bundles.map(x=>x.name),datasets:[{label:'درجة الطلب',data:bundles.map(x=>x.demand)},{label:'عدد متوقع للبيع',data:bundles.map(x=>x.qty)}]},{indexAxis:'y'});const scenarios=[713,799,900,1000,1200,1500];const f=finance(data);chart('revenueChart','bar',{labels:scenarios.map(x=>x+' ريال'),datasets:[{label:'إيراد قبل الخصم',data:scenarios.map(p=>total*p)},{label:'بعد الضريبة وتمارا',data:scenarios.map(p=>total*p*VAT_NET_FACTOR*TAMARA_FACTOR)},{label:'صافي الربح بعد كل التكاليف',data:scenarios.map(p=>total*p*VAT_NET_FACTOR*TAMARA_FACTOR-total*COST_SAR-f.trainerFee)}]});chart('segmentChart','doughnut',{labels:data.map(x=>x.segment),datasets:[{label:'كمية الأكواد',data:data.map(x=>x.qty)}]},{noScales:true});chart('riskChart','bar',{labels,datasets:[{label:'مخاطر عدم التصريف %',data:data.map(x=>Math.min(100,Math.round(x.riskBase+(60-days)*0.9)))}]});chart('priorityChart','radar',{labels:data.map(x=>x.code),datasets:[{label:'أولوية تنفيذية',data:data.map(x=>Math.round((x.demand+x.ease+(100-x.riskBase))/3))}]},{noScales:true});}
function toggleTheme(){document.body.dataset.theme=document.body.dataset.theme==='dark'?'light':'dark';render();}
function resetFilters(){document.getElementById('codeFilter').value='all';document.getElementById('segmentFilter').value='all';document.getElementById('priorityFilter').value='all';document.getElementById('daysRange').value=60;document.getElementById('sellPriceRange').value=900;document.getElementById('trainerFee').value=0;render();}
initFilters();render();
</script>
</body>
</html>
